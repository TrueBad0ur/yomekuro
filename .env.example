POSTGRES_USER=yomekuro
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yomekuro
YOMEKURO_ADMIN_USER=admin
YOMEKURO_ADMIN_PASSWORD=change-me

# Only used by docker-compose.prod.yml — the released tag to pull, e.g. 2.0
# (published by .github/workflows/release.yml as truebad0ur/yomekuro:2.0 and
# truebad0ur/converter:gpu-2.0). Not used by docker-compose.yml/.dev.yml,
# which build from source instead.
YOMEKURO_VERSION=2.0
