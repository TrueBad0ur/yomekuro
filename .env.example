POSTGRES_USER=yomekuro
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yomekuro
YOMEKURO_ADMIN_USER=admin
YOMEKURO_ADMIN_PASSWORD=change-me

# Only used by docker-compose.prod.yml — not used by docker-compose.yml/.dev.yml,
# which build from source instead. yomekuro (Go server) and converter (Python
# OCR pipeline) are versioned and pushed independently, so these are separate
# variables — bump either one on its own without forcing a rebuild of the other.
YOMEKURO_VERSION=2.3.3
CONVERTER_VERSION=2.3
