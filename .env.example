POSTGRES_USER=yomekuro
POSTGRES_PASSWORD=change-me
POSTGRES_DB=yomekuro
YOMEKURO_ADMIN_USER=admin
YOMEKURO_ADMIN_PASSWORD=change-me

# Image tags to pull — only used by docker-compose.prod.yml
YOMEKURO_VERSION=3.0
CONVERTER_VERSION=3.0

# Settings page conversion-job poll interval, ms
YOMEKURO_JOBS_POLL_INTERVAL_MS=20000
# Open EPUB archives kept in the LRU cache
YOMEKURO_ZIP_CACHE_SIZE=20

# converter-worker's job-queue/library poll interval
CONVERTER_POLL_INTERVAL=10s
# Log 1 in every N tqdm page-progress updates (1 = every page)
CONVERTER_PROGRESS_EVERY=10
# Retry attempts for a failed mokuro run, and delay between them
CONVERTER_MOKURO_RETRIES=3
CONVERTER_MOKURO_RETRY_DELAY=5s
